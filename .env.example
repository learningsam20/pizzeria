# ── AI (OpenRouter preferred when both are set) ──────────────────────────────
# If OPENROUTER_API_KEY is set, it is used instead of GEMINI_API_KEY.

# OpenRouter — https://openrouter.ai/
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_TEMPERATURE="0.3"
# OPENROUTER_MAX_TOKENS="2048"
# OPENROUTER_TOP_P="0.9"
# OPENROUTER_SITE_URL="https://your-app.example.com"
# OPENROUTER_APP_NAME="Slice of Heaven Pizzeria"

# Google Gemini (fallback when OpenRouter is not configured)
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_MODEL="gemini-3.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="YOUR_SUPABASE_URL"

# SUPABASE_ANON_KEY: The anonymous API key of your Supabase project.
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# RESEND_API_KEY: Optional — emails staff temporary passwords directly to new users.
# RESEND_API_KEY="re_..."

# STAFF_EMAIL_FROM: Sender for staff welcome emails (required with RESEND_API_KEY).
# STAFF_EMAIL_FROM="Slice of Heaven <onboarding@yourdomain.com>"
